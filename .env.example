# Port to expose the MemPalace MCP server on
PORT=8000

# Path on your host machine to mount as the import folder.
# This is where mempalace will mine conversation exports from.
# Example: /home/youruser/claude-exports
IMPORT_PATH=/path/to/your/imports

# Memory limit for the container. MemPalace loads embeddings into RAM.
# 4g is a safe minimum; 6g+ recommended if you have a large palace.
MEM_LIMIT=6g
